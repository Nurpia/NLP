<!DOCTYPE html>
<html>
<head>

    <title>NLP Translator</title>

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

<div class="main-container">

    <!-- ===================== -->
    <!-- TRANSLATOR BOX -->
    <!-- ===================== -->
    <div class="translator-box">

        <h1>NLP Translator + OCR AI</h1>

        <!-- ===================== -->
        <!-- TOGGLE UPLOAD -->
        <!-- ===================== -->

        <button
            class="toggle-upload-btn"
            onclick="toggleUpload()"
        >
            📂 Upload Dokumen / Gambar
        </button>

        <!-- PANEL UPLOAD -->
        <div id="uploadPanel" class="upload-panel">

            <label for="docInput" class="custom-file-upload">
                <span>📁 Pilih File</span>
            </label>

            <input
                type="file"
                id="docInput"
                accept=".png,.jpg,.jpeg,.pdf"
            >

            <div
                id="fileName"
                class="file-name"
            >
                Belum ada file dipilih
            </div>

            <button
                class="upload-btn"
                onclick="uploadDoc()"
            >
                🚀 Upload Sekarang
            </button>

        </div>

        <!-- TEXT INPUT -->
        <textarea
            id="text"
            placeholder="Masukkan teks atau hasil OCR"
        ></textarea>

        <!-- LANGUAGE SELECT -->
        <div class="select-box">

            <select id="source">
                <option value="id">Indonesia</option>
                <option value="en">Inggris</option>
                <option value="ar">Arab</option>
                <option value="zh-CN">China</option>
                <option value="ko">Korea</option>
            </select>

            <select id="target">
                <option value="en">Inggris</option>
                <option value="id">Indonesia</option>
                <option value="ar">Arab</option>
                <option value="zh-CN">China</option>
                <option value="ko">Korea</option>
            </select>

        </div>

        <!-- TRANSLATE BUTTON -->
        <button onclick="translateText()">
            Translate
        </button>

        <h2>Hasil Terjemahan</h2>

        <div id="result"></div>

    </div>

    <!-- ===================== -->
    <!-- HISTORY BOX -->
    <!-- ===================== -->
    <div class="history-box">

        <div class="history-header">

            <h2>History</h2>

            <a href="/delete-all" class="delete-all-btn">
                Hapus Semua
            </a>

        </div>

        <% if(histories && histories.length > 0){ %>

            <% histories.forEach((item) => { %>

                <div class="history-card">

                    <div class="lang-row">

                        <span><%= item.bahasa_asal %></span>
                        <span>→</span>
                        <span><%= item.bahasa_tujuan %></span>

                    </div>

                    <div class="history-text">
                        <%= item.text_asal %>
                    </div>

                    <div class="history-result">
                        <%= item.text_hasil %>
                    </div>

                    <button
                        class="use-btn"
                        onclick="useHistory(
                            '<%= item.text_asal %>',
                            '<%= item.text_hasil %>',
                            '<%= item.bahasa_asal %>',
                            '<%= item.bahasa_tujuan %>'
                        )"
                    >
                        Gunakan
                    </button>

                    <a class="delete-btn" href="/delete/<%= item.id %>">
                        Hapus
                    </a>

                </div>

            <% }) %>

        <% } else { %>

            <p>Belum ada history</p>

        <% } %>

    </div>

</div>

<script src="/js/script.js"></script>

</body>
</html>
